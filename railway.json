{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "pnpm install --frozen-lockfile && cd artifacts/api-server && node build.mjs",
    "watchPatterns": ["artifacts/api-server/**", "lib/**"]
  },
  "deploy": {
    "startCommand": "cd artifacts/api-server && node --enable-source-maps ./dist/index.mjs",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
